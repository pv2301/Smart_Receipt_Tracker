{
  "version": 2,
  "name": "notinha",
  "installCommand": "npm run install:flutter",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/build/web",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "excludeFiles": "{frontend/**,flutter/**,flutter_sdk/**,flutter_sdk/**/.git/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
