{
  "version": 2,
  "name": "smart-receipt-tracker",
  "installCommand": "bash scripts/install-flutter.sh",
  "buildCommand": "bash scripts/build-web.sh",
  "outputDirectory": "frontend/build/web",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
