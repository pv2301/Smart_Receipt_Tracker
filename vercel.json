{
  "version": 2,
  "name": "notinha",
  "installCommand": "npm run install:flutter",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/build/web",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
